# Tastebank — vereiste omgevingsvariabelen (zie README voor de setupstappen)

# Van @BotFather (nieuw bot-token)
TELEGRAM_BOT_TOKEN=

# Zelf genereren, bijv.: openssl rand -hex 32
# Wordt meegegeven aan setWebhook en gecheckt op elke webhook-call
TELEGRAM_SECRET_TOKEN=

# Jouw eigen Telegram chat-id (stuur een bericht naar de bot en lees het id
# uit de webhook-payload, of gebruik @userinfobot)
ALLOWED_CHAT_ID=

# Supabase project (Settings > API)
SUPABASE_URL=
# Service role key — ALLEEN server-side, nooit met NEXT_PUBLIC_-prefix
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=

# Google AI Studio API key (aistudio.google.com)
GEMINI_API_KEY=
